<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Distribution outside the App Store, no notarization required for personal use. -->
    <key>method</key>
    <string>mac-application</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <!-- Set to true to strip Swift standard libraries if they are already embedded
         in the OS (reduces .app size on modern macOS). -->
    <key>stripSwiftSymbols</key>
    <true/>
</dict>
</plist>
